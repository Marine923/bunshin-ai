# ───────────────────────────────────────────────────────────
# CRITICAL: Personal data (never commit)
# ───────────────────────────────────────────────────────────
# bunshin runtime data (database with all your memories, credentials)
.bunshin/
data.db*
gmail.json
calendar.json
entities.json
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# LINE export files (may contain private chat history)
*[LINE]*.txt
*line_export*

# Calendar / Gmail credentials backups
*.bak.*

# ───────────────────────────────────────────────────────────
# Python
# ───────────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
.env
.env.local
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ───────────────────────────────────────────────────────────
# IDE / Editor
# ───────────────────────────────────────────────────────────
.idea/
.vscode/
.cursor/
*.swp
*.swo
.DS_Store

# ───────────────────────────────────────────────────────────
# Claude Code project files (may contain context)
# ───────────────────────────────────────────────────────────
.mcp.json
.claude/

# ───────────────────────────────────────────────────────────
# Node / Electron
# ───────────────────────────────────────────────────────────
node_modules/
electron-app/dist/
# Built icon outputs (regenerated by `npm run icon:build` from icon.svg)
electron-app/build/icon.icns
electron-app/build/icon.png
electron-app/build/icon.iconset/
# Keep the SVG source of truth even though `build/` is ignored above for Python
!electron-app/build/
!electron-app/build/icon.svg

# ───────────────────────────────────────────────────────────
# Rust / Tauri (alternate desktop wrapper, kept for future)
# ───────────────────────────────────────────────────────────
tauri-app/src-tauri/target/
tauri-app/src-tauri/Cargo.lock
tauri-app/dist/

# ───────────────────────────────────────────────────────────
# OS / Misc
# ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.tmp
